# Database
DATABASE_URL=postgresql://youniversity:youniversity@localhost:5432/youniversity2

# Redis (realtime pub/sub)
REDIS_URL=redis://localhost:6379

# MinIO / S3 (local dev via docker-compose)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=youniversity2
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=eu-central-1

# Auth
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d
# Session timeouts (ms): 1h neaktivity, 30min po zatvorení browsera
SESSION_IDLE_MS=3600000
SESSION_BROWSER_CLOSED_MS=1800000

# OAuth — Google (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — Microsoft 365 / Entra ID (https://portal.azure.com → App registrations)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# AI translation (OpenAI-compatible API — AWS Bedrock or OpenAI)
AI_TRANSLATION_API_URL=https://api.openai.com/v1
AI_TRANSLATION_API_KEY=
AI_TRANSLATION_MODEL=gpt-4o-mini

# App URLs
API_URL=http://localhost:3001
WEB_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# AWS (production)
# AWS_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Database
DATABASE_URL=postgresql://youniversity:youniversity@localhost:5432/youniversity2

# Redis (realtime pub/sub)
REDIS_URL=redis://localhost:6379

# MinIO / S3 (local dev via docker-compose)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=youniversity2
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=eu-central-1

# Auth
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d

# AI translation (OpenAI-compatible API — AWS Bedrock or OpenAI)
AI_TRANSLATION_API_URL=https://api.openai.com/v1
AI_TRANSLATION_API_KEY=
AI_TRANSLATION_MODEL=gpt-4o-mini

# App URLs
API_URL=http://localhost:3001
WEB_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173


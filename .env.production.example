# Skopíruj na server ako .env a uprav hodnoty.
# PUBLIC_URL = IP alebo doména Lightsail inštancie (bez lomítka na konci)

PUBLIC_URL=http://YOUR_LIGHTSAIL_IP

POSTGRES_PASSWORD=change-me-strong-db-password

DATABASE_URL=postgresql://youniversity:change-me-strong-db-password@postgres:5432/youniversity2
REDIS_URL=redis://redis:6379

S3_ENDPOINT=http://minio:9000
S3_BUCKET=youniversity2
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change-me-minio-secret
S3_REGION=eu-central-1

JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_EXPIRES_IN=7d
SESSION_IDLE_MS=3600000
SESSION_BROWSER_CLOSED_MS=1800000

API_URL=http://YOUR_LIGHTSAIL_IP
WEB_URL=http://YOUR_LIGHTSAIL_IP
CORS_ORIGIN=http://YOUR_LIGHTSAIL_IP

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

AI_TRANSLATION_API_URL=https://api.openai.com/v1
AI_TRANSLATION_API_KEY=
AI_TRANSLATION_MODEL=gpt-4o-mini

# Skopíruj na server ako .env a uprav hodnoty.
# PUBLIC_URL = primárna HTTPS doména (bez lomítka na konci)
# Po nasadení spusti: chmod +x deploy/aws-harden-secrets.sh && ./deploy/aws-harden-secrets.sh

NODE_ENV=production

PUBLIC_URL=https://elearning.batacon.sk

POSTGRES_PASSWORD=change-me-strong-db-password

DATABASE_URL=postgresql://youniversity:change-me-strong-db-password@postgres:5432/youniversity2
REDIS_URL=redis://redis:6379

S3_ENDPOINT=http://minio:9000
S3_BUCKET=youniversity2
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change-me-minio-secret
S3_REGION=eu-central-1

JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_EXPIRES_IN=7d
SESSION_IDLE_MS=3600000
SESSION_BROWSER_CLOSED_MS=1800000

API_URL=https://elearning.batacon.sk
WEB_URL=https://elearning.batacon.sk
CORS_ORIGIN=https://elearning.batacon.sk
COOKIE_SECURE=true

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Ak v DB nie je žiadny system_admin, pri štarte API povýši tento účet (musí už existovať, napr. cez OAuth).
BOOTSTRAP_SYSTEM_ADMIN_EMAIL=batarobo@gmail.com

AI_TRANSLATION_API_URL=https://api.openai.com/v1
AI_TRANSLATION_API_KEY=
AI_TRANSLATION_MODEL=gpt-4o-mini

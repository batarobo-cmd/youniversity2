{
  "name": "youniversity2",
  "version": "0.8.0",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:api": "bun run --filter @youniversity2/api dev",
    "dev:web": "bun run --filter @youniversity2/web dev",
    "build": "bun run --filter '*' build",
    "db:generate": "bun run --filter @youniversity2/api db:generate",
    "db:migrate": "bun run --filter @youniversity2/api db:migrate",
    "db:push": "bun run --filter @youniversity2/api db:push",
    "db:seed": "bun run --filter @youniversity2/api db:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:prod:up": "docker compose -f docker-compose.prod.yml up -d --build",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "docker:prod:logs": "docker compose -f docker-compose.prod.yml logs -f",
    "docker:prod:init-db": "docker compose -f docker-compose.prod.yml exec api bun run db:push && docker compose -f docker-compose.prod.yml exec api bun run db:ensure-demo"
  }
}
